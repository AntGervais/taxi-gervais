---
const services = [
  {
    icon: "fas fa-calendar-check",
    title: "Déplacements du quotidien",
    body: "Courses, rendez-vous personnels ou médicaux. Taxi conventionné agréé CPAM pour vos transports médicaux pris en charge.",
    href: "/transport-medical-cpam/",
    cta: "Transport médical CPAM",
  },
  {
    icon: "fas fa-train",
    title: "Gares & aéroports",
    body: "Liaisons régulières vers la gare SNCF et l'aéroport Nantes Atlantique. Ponctualité garantie, aide aux bagages et accueil personnalisé.",
    href: "/taxi-gare-aeroport-nantes/",
    cta: "En savoir plus",
  },
  {
    icon: "fas fa-briefcase",
    title: "Transport professionnel",
    body: "Rendez-vous, transferts et séminaires. Service discret et conduite souple pour travailler ou vous reposer sereinement à bord.",
    href: "/taxi-professionnel-entreprise/",
    cta: "En savoir plus",
  },
  {
    icon: "fas fa-car-crash",
    title: "Rapatriement en cas de panne",
    body: "Assistance 7j/7 pour vous et votre famille. Véhicule 8 places pour accueillir tous les passagers et bagages, toutes distances.",
    href: "/taxi-rapatriement-panne-longue-distance/",
    cta: "En savoir plus",
  },
];
---

<section id='services' class='bg-white py-20 md:py-24'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='mb-14'>
      <p
        class='mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-yellow-600'>
        Nos prestations
      </p>
      <h2 class='text-3xl font-bold text-slate-900 md:text-4xl'>
        Un taxi pour chacun de vos trajets en Vendée
      </h2>
    </div>

    <div class='grid gap-6 sm:grid-cols-2 xl:grid-cols-4'>
      {
        services.map((service) => (
          <a
            href={service.href}
            class='card-accent group flex h-full flex-col rounded-2xl bg-white p-7 shadow-soft ring-1 ring-slate-200 transition duration-300 hover:-translate-y-1 hover:shadow-soft-lg'>
            <span class='mb-6 flex h-14 w-14 items-center justify-center rounded-xl bg-slate-100 text-xl text-slate-700 transition duration-300 group-hover:bg-yellow-400 group-hover:text-slate-900'>
              <i class={service.icon} />
            </span>
            <h3 class='text-lg font-bold text-slate-900'>{service.title}</h3>
            <p class='mt-3 text-sm leading-relaxed text-slate-600'>
              {service.body}
            </p>
            <span class='mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-semibold text-slate-900 transition-all group-hover:gap-2.5 group-hover:text-yellow-700'>
              {service.cta}
              <i class='fas fa-arrow-right text-xs' />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
