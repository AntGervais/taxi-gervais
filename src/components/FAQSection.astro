---
import { Icon } from 'astro-icon/components';

interface Props {
  faqs: Array<{ question: string; answer: string }>;
  heading?: string;
}

const { faqs, heading = 'Questions Fréquentes' } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---
<section class='py-20 bg-gray-50'>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <div class='text-center mb-16'>
      <h2 class='text-3xl font-bold text-slate-900'>{heading}</h2>
      <div class='w-20 h-1 bg-yellow-400 mx-auto mt-4'></div>
    </div>
    <div class='grid md:grid-cols-2 gap-8 max-w-5xl mx-auto'>
      {faqs.map((faq) => (
        <div class='bg-white p-6 rounded-xl shadow-md'>
          <div class='flex items-start'>
            <Icon name='lucide:circle-help' class='text-yellow-500 mt-1 mr-3 flex-shrink-0' size={20} />
            <div>
              <h3 class='font-bold text-slate-900 mb-2'>{faq.question}</h3>
              <p class='text-gray-600 text-sm'>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<script type='application/ld+json' set:html={JSON.stringify(faqSchema)} />
