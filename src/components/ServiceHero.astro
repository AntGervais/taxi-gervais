---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  highlightedText: string;
  description: string;
  ctaText: string;
  ctaTextShort?: string;
  badgeText?: string;
  badgeIcon?: string;
  badgeColor?: string;
  bgColor?: string;
}

const {
  title,
  highlightedText,
  description,
  ctaText,
  ctaTextShort = 'Réserver',
  badgeText,
  badgeIcon,
  badgeColor = 'bg-yellow-400 text-slate-900',
  bgColor = 'bg-slate-900',
} = Astro.props;
---
<section class={`${bgColor} text-white py-20`}>
  <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
    <div class='max-w-3xl'>
      {badgeText && (
        <div class={`inline-block ${badgeColor} px-4 py-2 rounded-full text-sm font-bold mb-6`}>
          {badgeIcon && <Icon name={badgeIcon} size={16} class='mr-2 inline' />}
          {badgeText}
        </div>
      )}
      <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
        {title} <span class='text-yellow-400'>{highlightedText}</span>
      </h1>
      <p class='text-xl text-white mb-8'>
        {description}
      </p>
      <a
        href='tel:0633968023'
        class='inline-flex flex-col sm:flex-row items-center gap-2 bg-yellow-400 text-slate-900 px-6 sm:px-8 py-4 rounded-full font-bold hover:bg-yellow-500 transition transform hover:scale-105 text-lg text-center'>
        <span class='flex items-center'>
          <Icon name='lucide:phone' size={20} class='mr-2' />
          <span class='hidden sm:inline'>{ctaText}</span>
          <span class='sm:hidden'>{ctaTextShort}</span>
        </span>
        <span class='whitespace-nowrap'>06 33 96 80 23</span>
      </a>
    </div>
  </div>
</section>
