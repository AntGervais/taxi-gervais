---
const year = new Date().getFullYear();

const nav = [
  { href: "/", label: "Accueil" },
  { href: "/#services", label: "Nos services" },
  { href: "/tarifs/", label: "Tarifs taxi" },
  { href: "/disponibilite-24h/", label: "Disponible 24h/24 et 7j/7" },
  { href: "/taxi-8-places-transport-groupe/", label: "Taxi 8 places" },
  { href: "/#contact", label: "Contact" },
];

const services = [
  { href: "/transport-medical-cpam/", label: "Transport médical CPAM" },
  { href: "/taxi-professionnel-entreprise/", label: "Transport professionnel" },
  { href: "/taxi-gare-aeroport-nantes/", label: "Gare & aéroport" },
  { href: "/taxi-rapatriement-panne-longue-distance/", label: "Rapatriement panne" },
  { href: "/taxi-nantes/", label: "Taxi Nantes" },
  { href: "/taxi-la-tranche-sur-mer/", label: "Taxi La Tranche-sur-Mer" },
];
---

<footer class='border-t border-slate-800 bg-slate-900 text-slate-400'>
  <div class='mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8'>
    <div class='grid grid-cols-1 gap-10 md:grid-cols-3'>
      <div>
        <a href='/' class='inline-flex items-center gap-2.5'>
          <span class='rounded-lg bg-yellow-400 px-2 py-1.5 text-slate-900'>
            <i class='fas fa-taxi'></i>
          </span>
          <span class='text-lg font-bold text-white'>TAXI GERVAIS</span>
        </a>
        <p class='mt-4 text-sm'>Commune de stationnement : La Roche-sur-Yon (85)</p>
        <p class='mt-3 text-sm'>
          <i class='fas fa-phone-alt mr-2 text-yellow-400'></i>
          <a
            href='tel:0633968023'
            class='tabular-nums transition hover:text-yellow-400'
            >06 33 96 80 23</a
          >
        </p>
        <p class='mt-2 text-sm'>
          <i class='fas fa-envelope mr-2 text-yellow-400'></i>
          <a
            href='mailto:Tag85@gmx.fr'
            class='transition hover:text-yellow-400'>Tag85@gmx.fr</a
          >
        </p>
        <p class='mt-4 flex items-center gap-2 text-sm'>
          <span class='flex text-yellow-400' aria-hidden='true'>
            <i class='fas fa-star text-xs'></i>
            <i class='fas fa-star text-xs'></i>
            <i class='fas fa-star text-xs'></i>
            <i class='fas fa-star text-xs'></i>
            <i class='fas fa-star text-xs'></i>
          </span>
          <span class='tabular-nums'>5,0 · 141 avis Google</span>
        </p>
      </div>

      <nav aria-label='Navigation du pied de page'>
        <h2 class='mb-4 text-sm font-bold uppercase tracking-wider text-white'>
          Navigation
        </h2>
        <ul class='space-y-2.5 text-sm'>
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class='transition hover:text-yellow-400'>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label='Nos services'>
        <h2 class='mb-4 text-sm font-bold uppercase tracking-wider text-white'>
          Nos services
        </h2>
        <ul class='space-y-2.5 text-sm'>
          {
            services.map((item) => (
              <li>
                <a
                  href={item.href}
                  class='inline-flex items-center gap-2 transition hover:text-yellow-400'>
                  <i class='fas fa-chevron-right text-[10px] text-yellow-400/70' />
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class='mt-10 border-t border-slate-800 pt-6 text-center text-xs text-slate-500'>
      © <span class='tabular-nums'>{year}</span> Taxi Anthony Gervais — La Roche-sur-Yon. Tous droits réservés.
    </div>
  </div>
</footer>
