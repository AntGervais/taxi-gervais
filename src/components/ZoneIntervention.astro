---
const zones = [
  {
    icon: "fas fa-map-marker-alt",
    title: "Vendée & littoral",
    detail: "Les Sables-d'Olonne, La Tranche-sur-Mer",
  },
  {
    icon: "fas fa-train",
    title: "Nantes & aéroport",
    detail: "Gare SNCF, aéroport Atlantique",
  },
  {
    icon: "fas fa-map-marked-alt",
    title: "Stationnement",
    detail: "La Roche-sur-Yon (85000)",
  },
];
---

<section id='zone' class='bg-slate-50 py-20 md:py-24'>
  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='mb-12'>
      <p
        class='mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-yellow-600'>
        Zone d'intervention
      </p>
      <h2 class='text-3xl font-bold text-slate-900 md:text-4xl'>
        Toute la Vendée, de La Roche au bord de mer
      </h2>
      <p class='mt-5 max-w-3xl text-lg leading-relaxed text-slate-600'>
        Basé à <span class='font-semibold text-slate-900'>La Roche-sur-Yon</span
        >, Anthony Gervais intervient dans toute la Vendée et ses stations
        balnéaires. Liaison régulière <a
          href='/taxi-les-sables-d-olonne/'
          class='font-semibold text-slate-900 underline underline-offset-2 hover:text-yellow-700'
          >Les Sables-d'Olonne</a
        > et <a
          href='/taxi-la-tranche-sur-mer/'
          class='font-semibold text-slate-900 underline underline-offset-2 hover:text-yellow-700'
          >La Tranche-sur-Mer</a
        >. Taxi <a
          href='/taxi-nantes/'
          class='font-semibold text-slate-900 underline underline-offset-2 hover:text-yellow-700'
          >La Roche-sur-Yon ↔ Nantes</a
        > disponible pour la gare SNCF et l'aéroport Nantes Atlantique.
      </p>
    </div>

    <div class='grid gap-5 sm:grid-cols-2 lg:grid-cols-3'>
      {
        zones.map((zone) => (
          <div class='flex items-center gap-4 rounded-2xl bg-white p-6 shadow-soft ring-1 ring-slate-200 transition duration-300 hover:-translate-y-0.5 hover:shadow-soft-lg'>
            <span class='flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-yellow-100 text-xl text-yellow-600'>
              <i class={zone.icon} />
            </span>
            <div class='min-w-0'>
              <p class='font-bold text-slate-900'>{zone.title}</p>
              <p class='mt-0.5 text-sm text-slate-500'>{zone.detail}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
