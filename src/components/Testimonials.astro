---
const reasons = [
  {
    title: "Chauffeur local",
    body: "Une connaissance parfaite de La Roche-sur-Yon, de ses raccourcis et du trafic vendéen.",
  },
  {
    title: "Confort & sécurité",
    body: "Véhicule récent, entretenu et propre, jusqu'à 8 places pour vos bagages.",
  },
  {
    title: "Conventionné CPAM",
    body: "Aucune avance de frais pour vos transports médicaux éligibles, sur prescription.",
  },
];
---

<section
  id='pourquoi'
  class='relative isolate overflow-hidden bg-slate-900 py-20 text-white md:py-24'>
  <div class='absolute inset-0 -z-10 grain'></div>
  <div
    class='pointer-events-none absolute -left-40 top-1/2 -z-10 h-[30rem] w-[30rem] -translate-y-1/2 rounded-full bg-yellow-400/10 blur-3xl'>
  </div>

  <div class='mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'>
    <div class='grid items-center gap-12 lg:grid-cols-2'>
      <div>
        <p
          class='mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-yellow-400'>
          Pourquoi Taxi Gervais
        </p>
        <h2 class='text-3xl font-bold md:text-4xl'>
          Un service de taxi sur lequel vous pouvez compter
        </h2>
        <ul class='mt-8 space-y-6'>
          {
            reasons.map((reason) => (
              <li class='flex items-start gap-4'>
                <span class='mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-yellow-400/15 text-yellow-400'>
                  <i class='fas fa-check text-sm' />
                </span>
                <span>
                  <span class='block font-semibold'>{reason.title}</span>
                  <span class='mt-1 block text-sm leading-relaxed text-slate-300'>
                    {reason.body}
                  </span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <figure
        class='relative rounded-2xl border border-white/10 bg-slate-800/80 p-8 shadow-soft-lg backdrop-blur'>
        <div class='relative'>
          <div class='mb-4 flex text-yellow-400' aria-label='Note 5 sur 5'>
            <i class='fas fa-star'></i>
            <i class='fas fa-star'></i>
            <i class='fas fa-star'></i>
            <i class='fas fa-star'></i>
            <i class='fas fa-star'></i>
          </div>
          <blockquote class='text-lg leading-relaxed tabular-nums text-slate-100'>
            « Quelle chance d'avoir connu Anthony dans cette période de
            traitement si difficile. Je recommande à 400 %, sa conduite est
            excellentissime. »
          </blockquote>
          <figcaption
            class='mt-6 flex items-center gap-3 border-t border-white/10 pt-6'>
            <span
              class='flex h-11 w-11 items-center justify-center rounded-full bg-yellow-400 font-bold text-slate-900'>
              S
            </span>
            <span class='flex-1'>
              <span class='block text-sm font-semibold'>Sophie M.</span>
              <span class='block text-xs text-slate-400'>Transport médical</span>
            </span>
            <a
              href='#avis'
              class='inline-flex items-center gap-1.5 text-xs font-semibold text-slate-300 transition hover:text-yellow-400'>
              <i class='fab fa-google'></i>
              <span class='tabular-nums'>Lire les 141 avis</span>
            </a>
          </figcaption>
        </div>
      </figure>
    </div>
  </div>
</section>
