---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MobileCallButton from "../components/MobileCallButton.astro";
import FAQSection from "../components/FAQSection.astro";
import { Icon } from 'astro-icon/components';

const faqs = [
  {
    question: "Combien de temps à l'avance dois-je réserver ?",
    answer: "Je recommande de réserver au moins 24h à l'avance. Pour les urgences, appelez-moi : je ferai mon maximum pour vous accommoder."
  },
  {
    question: "Que se passe-t-il si j'oublie ma carte Vitale ?",
    answer: "Sans carte Vitale, je ne peux pas appliquer le tiers payant. Vous devrez régler le trajet et vous faire rembourser par votre CPAM."
  },
  {
    question: "Puis-je être accompagné lors du transport ?",
    answer: "Oui, si votre prescription le mentionne. Mon véhicule 8 places peut accueillir un ou plusieurs accompagnants."
  }
];
---

<Layout
  title='Transport Médical Conventionné CPAM La Roche-sur-Yon - Taxi Gervais'
  description="Taxi conventionné CPAM à La Roche-sur-Yon. Pas d'avance de frais pour vos transports médicaux éligibles. Tiers payant accepté pour consultations, examens et traitements.">
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section
      class='bg-slate-900 text-white py-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='max-w-3xl'>
          <div
            class='inline-block bg-yellow-400 text-slate-900 px-4 py-2 rounded-full text-sm font-bold mb-6'>
            <Icon name='lucide:heart-pulse' size={16} class='mr-2' />
            Service Conventionné CPAM
          </div>
          <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
            Transport Médical Conventionné CPAM
          </h1>
          <p class='text-xl text-gray-300 mb-8'>
            Taxi conventionné à La Roche-sur-Yon. Avec une prescription médicale
            valide, vous voyagez sans avance de frais : je facture directement
            votre CPAM et mutuelle.
          </p>
          <a
            href='tel:0633968023'
            class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-500 transition transform hover:scale-105'>
            <Icon name='lucide:phone' size={20} class='mr-2' />
            06 33 96 80 23
          </a>
        </div>
      </div>
    </section>

    <!-- Conditions d'éligibilité -->
    <section id='conditions' class='py-20 bg-gray-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Qui Peut Bénéficier du Tiers Payant CPAM ?
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='grid md:grid-cols-2 gap-8 mb-12'>
          <div class='bg-white p-8 rounded-xl shadow-lg'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-yellow-600 text-2xl'>
              <Icon name='lucide:file-heart' size={24} />
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Prescription Médicale Obligatoire
            </h3>
            <p class='text-gray-700 mb-4'>
              Votre médecin, chirurgien-dentiste, sage-femme ou tout
              professionnel de santé habilité doit vous prescrire le transport
              sur ordonnance. Cette prescription doit mentionner :
            </p>
            <ul class='space-y-2 text-gray-700'>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Le motif médical du déplacement</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Le mode de transport (taxi)</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>La date et le lieu du rendez-vous</span>
              </li>
            </ul>
          </div>

          <div class='bg-white p-8 rounded-xl shadow-lg'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-yellow-600 text-2xl'>
              <Icon name='lucide:hospital' size={24} />
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Situations Médicales Éligibles
            </h3>
            <p class='text-gray-700 mb-4'>
              Le transport médical en taxi conventionné est pris en charge dans
              les cas suivants :
            </p>
            <ul class='space-y-2 text-gray-700'>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Hospitalisation (entrée, sortie, transfert)</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Affection de longue durée (ALD)</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Accident du travail ou maladie professionnelle</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Convocations pour examens médicaux CPAM</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Invalidité ou incapacité supérieure à 67%</span>
              </li>
              <li class='flex items-start'>
                <Icon name='lucide:check' size={16} class='text-yellow-500 mr-3 mt-1 flex-shrink-0' />
                <span>Chimiothérapie, radiothérapie, dialyse</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comment ça fonctionne -->
    <section class='py-20 bg-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-12'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Comment Ça Marche ?
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='bg-gray-50 rounded-xl p-8'>
          <ol class='space-y-4'>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >1</span
              >
              <p class='text-gray-700 pt-1'>
                Votre médecin vous prescrit un transport en taxi
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >2</span
              >
              <p class='text-gray-700 pt-1'>
                Vous me contactez pour réserver (prescription + carte Vitale
                requises)
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >3</span
              >
              <p class='text-gray-700 pt-1'>
                Je vous conduis à votre rendez-vous médical
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >4</span
              >
              <p class='text-gray-700 pt-1'>
                Je facture directement la CPAM et votre mutuelle
              </p>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- Avantages -->
    <section class='py-20 bg-gray-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Pourquoi Choisir Taxi Gervais ?
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='grid md:grid-cols-3 gap-8'>
          <div class='bg-white p-8 rounded-xl shadow-lg text-center'>
            <div
              class='bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-purple-600 text-2xl'>
              <Icon name='lucide:clock' size={24} />
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>Ponctualité</h3>
            <p class='text-gray-700'>
              Vos rendez-vous médicaux sont importants. Ponctualité
              irréprochable garantie.
            </p>
          </div>

          <div class='bg-white p-8 rounded-xl shadow-lg text-center'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-yellow-600 text-2xl'>
              <Icon name='lucide:heart-handshake' size={24} />
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Accompagnement
            </h3>
            <p class='text-gray-700'>
              Aide à la montée et descente, assistance personnalisée, conduite
              douce et attentionnée. Pour les patients nécessitant des
              déplacements réguliers, je propose aussi des <a
                href='/taxi-professionnel-entreprise/'
                class='text-blue-600 hover:underline'
                >forfaits mensuels adaptés</a
              >.
            </p>
          </div>

          <div class='bg-white p-8 rounded-xl shadow-lg text-center'>
            <div
              class='bg-indigo-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-indigo-600 text-2xl'>
              <Icon name='lucide:calendar' size={24} />
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Disponibilité 7j/7
            </h3>
            <p class='text-gray-700'>
              Service disponible tous les jours, même les week-ends et jours
              fériés.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection faqs={faqs} />

    <!-- Services connexes -->
    <section class='py-12 bg-gray-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h3 class='text-xl font-bold text-slate-900 mb-6 text-center'>
          Découvrez aussi mes autres services
        </h3>
        <div class='grid md:grid-cols-3 gap-4'>
          <a
            href='/taxi-gare-aeroport-nantes/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:plane' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Aéroport & Gare</h4>
              <p class='text-gray-600 text-sm'>Nantes Atlantique</p>
            </div>
          </a>
          <a
            href='/taxi-8-places-transport-groupe/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:users' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Taxi 8 Places</h4>
              <p class='text-gray-600 text-sm'>Transport groupe</p>
            </div>
          </a>
          <a
            href='/taxi-professionnel-entreprise/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:briefcase' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Transport Pro</h4>
              <p class='text-gray-600 text-sm'>Pour entreprises</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section
      class='py-20 bg-green-900 text-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <div
          class='bg-green-600 text-white w-20 h-20 rounded-full flex items-center justify-center mb-8 mx-auto text-3xl'>
          <Icon name='lucide:heart-pulse' size={30} />
        </div>
        <h2 class='text-3xl md:text-4xl font-bold mb-4'>
          Transport Médical Sans Avance de Frais
        </h2>
        <div class='bg-white rounded-xl p-6 max-w-2xl mx-auto mb-8 shadow-xl'>
          <p class='text-lg text-green-800 font-bold mb-4'>
            <Icon name='lucide:circle-check' size={20} class='text-green-600 mr-2 inline' />
            Prescription médicale valide ? Je facture directement votre CPAM
          </p>
          <p class='text-sm text-green-700 font-medium'>
            Vous n'avez rien à payer si vous êtes éligible au tiers payant
          </p>
        </div>
        <p class='text-xl text-gray-200 mb-8'>
          Vérifiez votre éligibilité et réservez votre transport médical
        </p>
        <a
          href='tel:0633968023'
          class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-500 transition transform hover:scale-105 text-lg'>
          <Icon name='lucide:phone' size={20} class='mr-2 inline' />
          Appelez-moi - 06 33 96 80 23
        </a>
        <p class='text-green-200 mt-6 text-sm font-semibold'>
          <Icon name='lucide:clock' size={16} class='mr-2 inline' />
          Réservation recommandée 24h à l'avance
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <MobileCallButton />
</Layout>
