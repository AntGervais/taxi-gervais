---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title='Transport Médical Conventionné CPAM La Roche-sur-Yon - Taxi Gervais'
  description="Taxi conventionné CPAM à La Roche-sur-Yon. Pas d'avance de frais pour vos transports médicaux éligibles. Tiers payant accepté pour consultations, examens et traitements.">
  <script type='application/ld+json' slot='head'>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Combien de temps à l'avance dois-je réserver ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Je recommande de réserver au moins 24h à l'avance. Pour les urgences, appelez-moi : je ferai mon maximum pour vous accommoder."
          }
        },
        {
          "@type": "Question",
          "name": "Que se passe-t-il si j'oublie ma carte Vitale ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sans carte Vitale, je ne peux pas appliquer le tiers payant. Vous devrez régler le trajet et vous faire rembourser par votre CPAM."
          }
        },
        {
          "@type": "Question",
          "name": "Puis-je être accompagné lors du transport ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui, si votre prescription le mentionne. Mon véhicule 8 places peut accueillir un ou plusieurs accompagnants."
          }
        }
      ]
    }
  </script>
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section
      class='bg-slate-900 text-white py-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='max-w-3xl'>
          <div
            class='inline-block bg-yellow-400 text-slate-900 px-4 py-2 rounded-full text-sm font-bold mb-6'>
            <i class='fas fa-heart-pulse mr-2'></i>
            Service Conventionné CPAM
          </div>
          <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
            Transport Médical Conventionné CPAM
          </h1>
          <p class='text-xl text-slate-300 mb-8'>
            Taxi conventionné à La Roche-sur-Yon. Avec une prescription médicale
            valide, vous voyagez sans avance de frais : je facture directement
            votre CPAM et mutuelle.
          </p>
          <a
            href='tel:0633968023'
            class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-300 transition duration-200 hover:-translate-y-0.5 active:scale-[0.98]'>
            <i class='fas fa-phone-alt mr-2'></i>
            06 33 96 80 23
          </a>
        </div>
      </div>
    </section>

    <!-- Conditions d'éligibilité -->
    <section id='conditions' class='py-20 bg-slate-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Qui Peut Bénéficier du Tiers Payant CPAM ?
          </h2>
        </div>

        <div class='grid md:grid-cols-2 gap-8 mb-12'>
          <div class='card-accent surface surface-interactive p-8'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-yellow-600 text-2xl'>
              <i class='fas fa-file-medical'></i>
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Prescription Médicale Obligatoire
            </h3>
            <p class='text-slate-700 mb-4'>
              Votre médecin, chirurgien-dentiste, sage-femme ou tout
              professionnel de santé habilité doit vous prescrire le transport
              sur ordonnance. Cette prescription doit mentionner :
            </p>
            <ul class='space-y-2 text-slate-700'>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Le motif médical du déplacement</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Le mode de transport (taxi)</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>La date et le lieu du rendez-vous</span>
              </li>
            </ul>
          </div>

          <div class='card-accent surface surface-interactive p-8'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 text-yellow-600 text-2xl'>
              <i class='fas fa-hospital'></i>
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Situations Médicales Éligibles
            </h3>
            <p class='text-slate-700 mb-4'>
              Le transport médical en taxi conventionné est pris en charge dans
              les cas suivants :
            </p>
            <ul class='space-y-2 text-slate-700'>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Hospitalisation (entrée, sortie, transfert)</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Affection de longue durée (ALD)</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Accident du travail ou maladie professionnelle</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Convocations pour examens médicaux CPAM</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Invalidité ou incapacité supérieure à 67%</span>
              </li>
              <li class='flex items-start'>
                <i class='fas fa-check text-yellow-500 mr-3 mt-1'></i>
                <span>Chimiothérapie, radiothérapie, dialyse</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comment ça fonctionne -->
    <section class='py-20 bg-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-12'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Comment Ça Marche ?
          </h2>
        </div>

        <div class='surface-inset p-8'>
          <ol class='space-y-4'>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >1</span
              >
              <p class='text-slate-700 pt-1'>
                Votre médecin vous prescrit un transport en taxi
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >2</span
              >
              <p class='text-slate-700 pt-1'>
                Vous me contactez pour réserver (prescription + carte Vitale
                requises)
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >3</span
              >
              <p class='text-slate-700 pt-1'>
                Je vous conduis à votre rendez-vous médical
              </p>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0'
                >4</span
              >
              <p class='text-slate-700 pt-1'>
                Je facture directement la CPAM et votre mutuelle
              </p>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- Avantages -->
    <section class='py-20 bg-slate-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Pourquoi Choisir Taxi Gervais ?
          </h2>
        </div>

        <div class='grid md:grid-cols-3 gap-8'>
          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-yellow-600 text-2xl'>
              <i class='fas fa-clock'></i>
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>Ponctualité</h3>
            <p class='text-slate-700'>
              Vos rendez-vous médicaux sont importants. Ponctualité
              irréprochable garantie.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-yellow-600 text-2xl'>
              <i class='fas fa-hand-holding-heart'></i>
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Accompagnement
            </h3>
            <p class='text-slate-700'>
              Aide à la montée et descente, assistance personnalisée, conduite
              douce et attentionnée. Pour les patients nécessitant des
              déplacements réguliers, je propose aussi des <a
                href='/taxi-professionnel-entreprise/'
                class='text-yellow-700 hover:underline'
                >forfaits mensuels adaptés</a
              >.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div
              class='bg-yellow-100 w-16 h-16 rounded-full flex items-center justify-center mb-6 mx-auto text-yellow-600 text-2xl'>
              <i class='fas fa-calendar-alt'></i>
            </div>
            <h3 class='text-xl font-bold mb-4 text-slate-900'>
              Disponibilité 7j/7
            </h3>
            <p class='text-slate-700'>
              Service disponible tous les jours, même les week-ends et jours
              fériés.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class='py-20 bg-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Questions Fréquentes
          </h2>
        </div>

        <div class='space-y-6'>
          <div class='surface-inset p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span>Combien de temps à l'avance dois-je réserver ?</span>
            </h3>
            <p class='text-slate-700 ml-8'>
              Je recommande de réserver au moins 24h à l'avance. Pour les
              urgences, appelez-moi : je ferai mon maximum pour vous accommoder.
            </p>
          </div>

          <div class='surface-inset p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span>Que se passe-t-il si j'oublie ma carte Vitale ?</span>
            </h3>
            <p class='text-slate-700 ml-8'>
              Sans carte Vitale, je ne peux pas appliquer le tiers payant. Vous
              devrez régler le trajet et vous faire rembourser par votre CPAM.
            </p>
          </div>

          <div class='surface-inset p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span>Puis-je être accompagné lors du transport ?</span>
            </h3>
            <p class='text-slate-700 ml-8'>
              Oui, si votre prescription le mentionne. Mon <a
                href='/taxi-8-places-transport-groupe/'
                class='text-yellow-600 hover:text-yellow-700 font-semibold'
                >véhicule 8 places</a
              > peut accueillir un ou plusieurs accompagnants.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services connexes -->
    <section class='py-12 bg-slate-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h3 class='text-xl font-bold text-slate-900 mb-6 text-center'>
          Découvrez aussi mes autres services
        </h3>
        <div class='grid md:grid-cols-3 gap-4'>
          <a
            href='/taxi-gare-aeroport-nantes/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-plane text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Aéroport & Gare</h4>
              <p class='text-slate-600 text-sm'>Nantes Atlantique</p>
            </div>
          </a>
          <a
            href='/taxi-8-places-transport-groupe/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-users text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Taxi 8 Places</h4>
              <p class='text-slate-600 text-sm'>Transport groupe</p>
            </div>
          </a>
          <a
            href='/taxi-professionnel-entreprise/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-briefcase text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Transport Pro</h4>
              <p class='text-slate-600 text-sm'>Pour entreprises</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section
      class='py-20 bg-green-900 text-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <div
          class='bg-green-600 text-white w-20 h-20 rounded-full flex items-center justify-center mb-8 mx-auto text-3xl'>
          <i class='fas fa-heart-pulse'></i>
        </div>
        <h2 class='text-3xl md:text-4xl font-bold mb-4'>
          Transport Médical Sans Avance de Frais
        </h2>
        <div class='surface p-6 max-w-2xl mx-auto mb-8'>
          <p class='text-lg text-green-800 font-bold mb-4'>
            <i class='fas fa-check-circle text-green-600 mr-2'></i>
            Prescription médicale valide ? Je facture directement votre CPAM
          </p>
          <p class='text-sm text-green-700 font-medium'>
            Vous n'avez rien à payer si vous êtes éligible au tiers payant
          </p>
        </div>
        <p class='text-xl text-slate-200 mb-8'>
          Vérifiez votre éligibilité et réservez votre transport médical
        </p>
        <a
          href='tel:0633968023'
          class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-300 transition duration-200 hover:-translate-y-0.5 active:scale-[0.98] text-lg'>
          <i class='fas fa-phone-alt mr-2'></i>
          Appelez-moi - 06 33 96 80 23
        </a>
        <p class='text-green-200 mt-6 text-sm font-semibold'>
          <i class='fas fa-clock mr-2'></i>
          Réservation recommandée 24h à l'avance
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Mobile Call Button -->
  <div class='fixed bottom-5 right-5 z-50 md:hidden'>
    <a
      href='tel:0633968023'
      aria-label='Appeler Taxi Anthony Gervais'
      class='relative flex h-16 w-16 items-center justify-center rounded-full bg-green-500 text-white shadow-soft-lg transition duration-200 hover:bg-green-600 active:scale-95'>
      <span class='absolute inset-0 -z-10 rounded-full bg-green-500/60 motion-safe:animate-ping'></span>
      <i class='fas fa-phone-alt text-2xl'></i>
    </a>
  </div>
</Layout>
