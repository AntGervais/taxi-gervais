---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCTA from "../components/ServiceCTA.astro";
import { Icon } from 'astro-icon/components';
---

<Layout
  title='Taxi La Roche-sur-Yon → Nantes | Aéroport & Gare | 24/24'
  description='Besoin d un taxi entre La Roche-sur-Yon et Nantes ? Transferts aéroport Nantes Atlantique et Gare de Nantes à tarif fixe. Véhicule 8 places. Réservez au 06 33 96 80 23.'>
  <Navbar />
  <main>
    <ServiceHero
      title="Taxi"
      highlightedText="La Roche-sur-Yon ↔ Nantes"
      description="Simplifiez vos trajets vers la cité des Ducs. Que ce soit pour l'aéroport, la gare ou un rendez-vous professionnel, profitez d'un trajet confortable et serein."
      ctaText="Réserver mon trajet Nantes"
      ctaTextShort="Réserver Nantes"
      badgeIcon="lucide:map-pin"
      badgeText="Liaison La Roche ↔ Nantes"
    />

    <!-- Content Sections -->
    <section class='py-20 bg-white'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='grid md:grid-cols-3 gap-8'>
          <div
            class='bg-slate-50 p-8 rounded-2xl border-t-4 border-blue-600 shadow-lg'>
            <div class='text-blue-600 mb-4'>
              <Icon name='lucide:plane' size={36} />
            </div>
            <h2 class='text-2xl font-bold text-slate-900 mb-4'>
              Aéroport Nantes Atlantique
            </h2>
            <p class='text-gray-600 mb-4 text-sm'>
              Évitez le stress du parking et des navettes. Je vous dépose
              directement devant votre terminal de départ.
            </p>
            <ul class='text-sm text-gray-500 space-y-2'>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> ~1h de trajet
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Aide aux bagages
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Suivi de votre vol
                (retour)
              </li>
            </ul>
          </div>
          <div
            class='bg-slate-50 p-8 rounded-2xl border-t-4 border-yellow-500 shadow-lg'>
            <div class='text-yellow-500 mb-4'>
              <Icon name='lucide:train-front' size={36} />
            </div>
            <h2 class='text-2xl font-bold text-slate-900 mb-4'>
              Gare de Nantes
            </h2>
            <p class='text-gray-600 mb-4 text-sm'>
              Pour vos correspondances TGV, profitez d'une liaison directe et
              rapide entre la Vendée et la gare de Nantes.
            </p>
            <ul class='text-sm text-gray-500 space-y-2'>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> ~50 min de trajet
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Accès direct quai
                de gare
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Accueil personnalisé
              </li>
            </ul>
          </div>
          <div
            class='bg-slate-50 p-8 rounded-2xl border-t-4 border-slate-900 shadow-lg'>
            <div class='text-slate-900 mb-4'>
              <Icon name='lucide:briefcase' size={36} />
            </div>
            <h2 class='text-2xl font-bold text-slate-900 mb-4'>
              Trajets Professionnels
            </h2>
            <p class='text-gray-600 mb-4 text-sm'>
              Un rendez-vous d'affaires à Nantes ? Travaillez à bord de mon
              véhicule spacieux pendant que je assure la route.
            </p>
            <ul class='text-sm text-gray-500 space-y-2'>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Facturation simplifiée
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Discrétion totale
              </li>
              <li>
                <Icon name='lucide:check' size={16} class='text-green-500 mr-2' /> Véhicule 8 places
                (Equipe)
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Table -->
    <section class='py-20 bg-slate-900 text-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h2 class='text-3xl font-bold mb-12 text-center'>
          Estimation de prix La Roche-Nantes
        </h2>
        <div class='overflow-hidden rounded-xl border border-slate-700'>
          <table class='w-full text-left'>
            <thead class='bg-slate-800 text-yellow-400'>
              <tr>
                <th class='p-4 border-b border-slate-700'>Destinations</th>
                <th class='p-4 border-b border-slate-700'>Tarif indicatif</th>
              </tr>
            </thead>
            <tbody class='text-gray-300'>
              <tr>
                <td class='p-4 border-b border-slate-700'
                  >La Roche → Nantes Aéroport</td
                >
                <td class='p-4 border-b border-slate-700'>à partir de 160€</td>
              </tr>
              <tr>
                <td class='p-4 border-b border-slate-700'
                  >La Roche → Nantes Centre / Gare</td
                >
                <td class='p-4 border-b border-slate-700'>à partir de 180€</td>
              </tr>
              <tr>
                <td class='p-4 border-b border-slate-700'
                  >La Roche → Nantes Sud</td
                >
                <td class='p-4 border-b border-slate-700'>à partir de 150€</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class='mt-6 text-sm text-gray-500 italic text-center'>
          *Tarifs indicatifs selon la réglementation en vigueur. Contactez-moi
          pour un devis précis.
        </p>
      </div>
    </section>

    <!-- Why Us -->
    <section class='py-20 bg-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h2 class='text-3xl font-bold text-slate-900 mb-8 text-center'>
          Pourquoi choisir Taxi Gervais ?
        </h2>
        <div class='grid md:grid-cols-2 gap-8'>
          <div class='flex items-start'>
            <Icon name='lucide:star' size={16} fill='currentColor' class='text-yellow-400 mr-4 mt-1' />
            <p class='text-gray-600'>
              <strong>Expérience :</strong> Excellente connaissance de l'itinéraire
              et du trafic nantais pour éviter les bouchons.
            </p>
          </div>
          <div class='flex items-start'>
            <Icon name='lucide:users' size={16} class='text-yellow-400 mr-4 mt-1' />
            <p class='text-gray-600'>
              <strong>Capacité :</strong> Transport jusqu'à 8 passagers et tous leurs
              bagages dans un seul taxi.
            </p>
          </div>
          <div class='flex items-start'>
            <Icon name='lucide:shield' size={16} class='text-yellow-400 mr-4 mt-1' />
            <p class='text-gray-600'>
              <strong>Sérénité :</strong> Pas de frais d'autoroute ou de parking cachés,
              tout est inclus dans le devis.
            </p>
          </div>
          <div class='flex items-start'>
            <Icon name='lucide:calendar' size={16} class='text-yellow-400 mr-4 mt-1' />
            <p class='text-gray-600'>
              <strong>Disponibilité :</strong> Réservation possible 24h/24 pour vos
              vols matinaux ou retours tardifs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ServiceCTA
      title="Prêt pour votre trajet vers Nantes ?"
      description="Obtenez votre devis gratuit et réservez votre véhicule en 2 minutes."
    />
  </main>
  <Footer />
</Layout>
