---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Icon } from 'astro-icon/components';
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCTA from "../components/ServiceCTA.astro";
---

<Layout
  title='Taxi La Roche-sur-Yon → Jard-sur-Mer | Transfert Plage Vendée'
  description='Besoin d un taxi entre La Roche-sur-Yon et Jard-sur-Mer ? Transport vers les plages sauvages et le port du Payré à tarif transparent. Véhicule 8 places. Réservez au 06 33 96 80 23.'>
  <Navbar />
  <main>
    <ServiceHero
      title="Taxi"
      highlightedText="La Roche-sur-Yon ↔ Jard-sur-Mer"
      description="Profitez des plages sauvages et du charme authentique de Jard-sur-Mer sans les contraintes de stationnement. Transport toutes distances vers cette perle du littoral vendéen."
      ctaText="Réserver mon trajet plage"
      badgeText="Direction le Littoral Vendéen"
      badgeIcon="lucide:umbrella"
    />

    <!-- Content Section -->
    <section class='py-20 bg-white text-gray-700'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16'>
        <h2 class='text-3xl font-bold text-slate-900 mb-4'>
          Votre Liaison Directe vers Jard-sur-Mer
        </h2>
        <div class='w-20 h-1 bg-yellow-400 mx-auto mb-8'></div>
        <p class='max-w-3xl mx-auto text-lg'>
          Située à environ 45 minutes de La Roche-sur-Yon, Jard-sur-Mer est
          une station balnéaire familiale réputée pour ses plages de sable fin
          et son cadre naturel préservé. Taxi Gervais vous y accompagne en tout
          confort.
        </p>
      </div>

      <div
        class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12'>
        <div class='space-y-6'>
          <div class='flex items-start'>
            <div class='bg-orange-100 p-3 rounded-full mr-4 text-orange-600'>
              <Icon name='lucide:users' size={24} />
            </div>
            <div>
              <h3 class='text-xl font-bold text-slate-900 mb-2'>
                Transport de Groupes & Familles
              </h3>
              <p>
                Grâce à mon <strong>véhicule 8 places</strong>, emmenez toute
                votre famille et vos équipements de plage (parasols, jeux,
                serviettes) sans supplément.
              </p>
            </div>
          </div>
          <div class='flex items-start'>
            <div class='bg-orange-100 p-3 rounded-full mr-4 text-orange-600'>
              <Icon name='lucide:map-pin' size={24} />
            </div>
            <div>
              <h3 class='text-xl font-bold text-slate-900 mb-2'>
                Desserte Complète
              </h3>
              <p>
                Je vous dépose où vous le souhaitez : la plage centrale, le port
                du Payré, les plages surveillées ou votre camping/location de
                vacances.
              </p>
            </div>
          </div>
          <div class='flex items-start'>
            <div class='bg-orange-100 p-3 rounded-full mr-4 text-orange-600'>
              <Icon name='lucide:coins' size={24} />
            </div>
            <div>
              <h3 class='text-xl font-bold text-slate-900 mb-2'>
                Tarif Transparent
              </h3>
              <p>
                Pas de mauvaise surprise liée au trafic estival. Le prix est
                calculé selon la réglementation ou convenu à l'avance pour les
                longs trajets.
              </p>
            </div>
          </div>
        </div>
        <div
          class='bg-slate-50 shadow-lg p-8 rounded-3xl border border-slate-100 flex flex-col justify-center'>
          <h3 class='text-2xl font-bold text-slate-900 mb-4'>Infos Trajet</h3>
          <ul class='space-y-4'>
            <li class='flex justify-between border-b border-slate-200 pb-2'>
              <span class='font-medium'>Distance :</span>
              <span>~36 km</span>
            </li>
            <li class='flex justify-between border-b border-slate-200 pb-2'>
              <span class='font-medium'>Temps estimé :</span>
              <span>40 à 50 minutes</span>
            </li>
            <li class='flex justify-between border-b border-slate-200 pb-2'>
              <span class='font-medium'>Estimation Prix (Jour) :</span>
              <span>à partir de 80€</span>
            </li>
            <li class='flex justify-between'>
              <span class='font-medium text-orange-600'>Disponibilité :</span>
              <span>7j/7 sur réservation</span>
            </li>
          </ul>
          <p class='mt-6 text-xs text-gray-500 italic'>
            *Les tarifs peuvent varier selon le point de départ précis et
            l'horaire de prise en charge.
          </p>
        </div>
      </div>
    </section>

    <!-- Destination Highlights -->
    <section class='py-20 bg-slate-900 text-white'>
      <div class='max-w-screen-xl mx-auto px-4'>
        <h2 class='text-3xl font-bold mb-12 text-center text-yellow-400'>
          Je dessers également tout le littoral
        </h2>
        <div class='grid grid-cols-2 md:grid-cols-4 gap-4'>
          <a href='/taxi-la-tranche-sur-mer/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            La Tranche-sur-Mer
          </a>
          <a href='/taxi-les-sables-d-olonne/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            Les Sables-d'Olonne
          </a>
          <a href='/taxi-saint-gilles-croix-de-vie/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            Saint-Gilles-Croix-de-Vie
          </a>
          <a href='/taxi-talmont-saint-hilaire/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            Talmont-Saint-Hilaire
          </a>
          <a href='/taxi-l-aiguillon-sur-mer/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            L'Aiguillon-sur-Mer
          </a>
          <a href='/taxi-saint-jean-de-monts/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            Saint-Jean-de-Monts
          </a>
          <a href='/taxi-la-faute-sur-mer/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            La Faute-sur-Mer
          </a>
          <a href='/taxi-noirmoutier/' class='p-4 text-center border border-slate-700 rounded-xl hover:bg-slate-800 hover:border-yellow-400 transition'>
            Noirmoutier
          </a>
        </div>
      </div>
    </section>

    <ServiceCTA
      title="Prêt pour le grand air ?"
      description="Réservez votre taxi pour Jard-sur-Mer et voyagez sans stress."
    />
  </main>
  <Footer />
</Layout>
