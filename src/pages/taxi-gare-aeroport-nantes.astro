---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import MobileCallButton from "../components/MobileCallButton.astro";
import FAQSection from "../components/FAQSection.astro";
import { Icon } from 'astro-icon/components';

const faqs = [
  {
    question: "À quelle heure dois-je prévoir le départ pour l'aéroport ?",
    answer: "Je recommande d'arriver 2h avant un vol européen et 3h avant un vol international. Comptez environ 1h de trajet + marge de sécurité. Je vous conseille sur l'heure de départ optimale."
  },
  {
    question: "Combien de bagages puis-je emporter ?",
    answer: "Mon véhicule 8 places dispose d'un grand coffre. Pour 1-4 passagers, vous pouvez emporter sans problème valises + bagages cabine. Précisez le nombre de bagages lors de la réservation."
  },
  {
    question: "Que se passe-t-il si mon vol est retardé ?",
    answer: "Pour les retours d'aéroport, je surveille votre vol en temps réel. Si votre avion a du retard, je m'adapte gratuitement (dans la limite du raisonnable)."
  },
  {
    question: "Le tarif inclut-il les frais d'autoroute ?",
    answer: "Oui, le tarif fixe que je vous annonce inclut tout : carburant, autoroute, retour à vide. Aucun supplément."
  }
];
---

<Layout
  title='Taxi Aéroport Nantes & Gare - La Roche-sur-Yon | Taxi Gervais'
  description="Transfert fiable vers l'aéroport Nantes Atlantique et les gares depuis La Roche-sur-Yon. Ponctualité garantie, véhicule 8 places, tarif fixe sur devis. Réservez votre taxi.">
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section
      class='bg-slate-900 text-white py-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='max-w-3xl'>
          <div
            class='inline-block bg-yellow-400 text-slate-900 px-4 py-2 rounded-full text-sm font-bold mb-6'>
            <Icon name='lucide:plane-takeoff' size={16} class='mr-2 inline' />
            Transfert Gare & Aéroport
          </div>
          <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
            Taxi Gare & Aéroport Nantes depuis La Roche-sur-Yon
          </h1>
          <p class='text-xl text-gray-300 mb-8'>
            Transfert professionnel vers l'aéroport Nantes Atlantique et les
            gares. Ponctualité garantie, aide aux bagages, véhicule 8 places
            spacieux. Ne ratez plus jamais votre train ou votre vol.
          </p>
          <a
            href='tel:0633968023'
            class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-500 transition transform hover:scale-105'>
            <Icon name='lucide:phone' size={20} class='mr-2 inline' />
            06 33 96 80 23
          </a>
        </div>
      </div>
    </section>

    <!-- Destinations principales -->
    <section class='py-20 bg-white'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Mes Destinations Principales
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='grid md:grid-cols-2 gap-8'>
          <!-- Aéroport Nantes -->
          <div
            class='bg-blue-50 p-8 rounded-xl shadow-lg border-t-4 border-blue-500'>
            <div class='flex items-start mb-6'>
              <div
                class='bg-blue-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl mr-4 flex-shrink-0'>
                <Icon name='lucide:plane' size={24} />
              </div>
              <div>
                <h3 class='text-2xl font-bold text-slate-900 mb-2'>
                  Aéroport Nantes Atlantique
                </h3>
                <p class='text-gray-600'>Code IATA : NTE</p>
              </div>
            </div>

            <div class='space-y-3 mb-6'>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:map-pin' size={16} class='text-blue-500 w-6 mr-3' />
                <span
                  ><strong>Distance :</strong> ~80 km depuis La Roche-sur-Yon</span
                >
              </div>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:clock' size={16} class='text-blue-500 w-6 mr-3' />
                <span><strong>Durée :</strong> Environ 1h de trajet</span>
              </div>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:euro' size={16} class='text-blue-500 w-6 mr-3' />
                <span><strong>Tarif :</strong> Sur devis (tarif fixe)</span>
              </div>
            </div>

            <div class='bg-white rounded-lg p-4 border-l-4 border-blue-500'>
              <h4 class='font-bold text-slate-900 mb-2 flex items-center'>
                <Icon name='lucide:circle-check' size={16} class='text-blue-500 mr-2' />
                Services inclus
              </h4>
              <ul class='text-sm text-gray-700 space-y-1'>
                <li>• Prise en charge à domicile</li>
                <li>• Aide au chargement des bagages</li>
                <li>• Dépose au terminal départ</li>
                <li>• Surveillance du trafic pour éviter les retards</li>
              </ul>
            </div>
          </div>

          <!-- Gare de Nantes -->
          <div
            class='bg-yellow-50 p-8 rounded-xl shadow-lg border-t-4 border-yellow-500'>
            <div class='flex items-start mb-6'>
              <div
                class='bg-yellow-500 text-white w-16 h-16 rounded-full flex items-center justify-center text-2xl mr-4 flex-shrink-0'>
                <Icon name='lucide:train-front' size={24} />
              </div>
              <div>
                <h3 class='text-2xl font-bold text-slate-900 mb-2'>
                  Gare SNCF de Nantes
                </h3>
                <p class='text-gray-600'>
                  Gare Nantes Sud (TGV, TER, Intercités)
                </p>
              </div>
            </div>

            <div class='space-y-3 mb-6'>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:map-pin' size={16} class='text-yellow-500 w-6 mr-3' />
                <span
                  ><strong>Distance :</strong> ~70 km depuis La Roche-sur-Yon</span
                >
              </div>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:clock' size={16} class='text-yellow-500 w-6 mr-3' />
                <span><strong>Durée :</strong> Environ 50 min de trajet</span>
              </div>
              <div class='flex items-center text-gray-700'>
                <Icon name='lucide:euro' size={16} class='text-yellow-500 w-6 mr-3' />
                <span><strong>Tarif :</strong> Sur devis (tarif fixe)</span>
              </div>
            </div>

            <div class='bg-white rounded-lg p-4 border-l-4 border-yellow-500'>
              <h4 class='font-bold text-slate-900 mb-2 flex items-center'>
                <Icon name='lucide:circle-check' size={16} class='text-yellow-500 mr-2' />
                Services inclus
              </h4>
              <ul class='text-sm text-gray-700 space-y-1'>
                <li>• Dépose/récupération devant la gare</li>
                <li>• Gestion des bagages lourds</li>
                <li>• Suivi des horaires de train en temps réel</li>
                <li>• Trajet retour possible</li>
              </ul>
            </div>
          </div>
        </div>

        <div class='mt-8 bg-gray-50 rounded-xl p-6 text-center'>
          <p class='text-gray-700 mb-4'>
            <Icon name='lucide:info' size={16} class='text-blue-500 mr-2 inline' />
            Je dessers également : <strong>Gare de La Roche-sur-Yon</strong>, <strong
              >Gare des Sables-d'Olonne</strong
            >, <strong>Gare d'Angers</strong>, et autres destinations sur
            demande.
          </p>
          <a
            href='tel:0633968023'
            class='text-yellow-600 hover:text-yellow-700 font-bold'>
            Appelez-moi pour un devis personnalisé →
          </a>
        </div>
      </div>
    </section>

    <!-- Pourquoi me choisir -->
    <section class='py-20 bg-gray-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Pourquoi Réserver un Taxi pour l'Aéroport ou la Gare ?
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='grid md:grid-cols-3 gap-8'>
          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-green-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-green-600 text-xl'>
              <Icon name='lucide:clock' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>
              Ponctualité Absolue
            </h3>
            <p class='text-gray-700 text-sm'>
              Je calcule le temps de trajet avec une marge de sécurité. Vous
              arrivez toujours à l'heure pour votre vol ou votre train.
            </p>
          </div>

          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-blue-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-blue-600 text-xl'>
              <Icon name='lucide:luggage' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>
              Aide aux Bagages
            </h3>
            <p class='text-gray-700 text-sm'>
              Je m'occupe du chargement et déchargement de vos valises. Véhicule
              8 places = grand coffre pour tous vos bagages.
            </p>
          </div>

          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-purple-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-purple-600 text-xl'>
              <Icon name='lucide:hand-coins' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>Tarif Fixe</h3>
            <p class='text-gray-700 text-sm'>
              Prix convenu à l'avance, pas de surprise à l'arrivée. Plus
              économique qu'un parking longue durée pour un voyage de plusieurs
              jours.
            </p>
          </div>

          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-yellow-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-yellow-600 text-xl'>
              <Icon name='lucide:users' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>
              Départ en Groupe
            </h3>
            <p class='text-gray-700 text-sm'>
              Jusqu'à 8 personnes dans le même véhicule avec mon <a
                href='/taxi-8-places-transport-groupe/'
                class='text-blue-600 hover:underline'>taxi 8 places</a
              >. Idéal pour les départs en famille ou entre amis. Un seul
              trajet, un seul prix.
            </p>
          </div>

          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-red-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-red-600 text-xl'>
              <Icon name='lucide:square-parking' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>
              Sans Stress de Parking
            </h3>
            <p class='text-gray-700 text-sm'>
              Pas de recherche de place, pas de frais de parking. Déposé
              directement devant le terminal ou la gare.
            </p>
          </div>

          <div class='bg-white p-6 rounded-xl shadow-lg'>
            <div
              class='bg-indigo-100 w-14 h-14 rounded-full flex items-center justify-center mb-4 text-indigo-600 text-xl'>
              <Icon name='lucide:moon' size={20} />
            </div>
            <h3 class='text-lg font-bold mb-3 text-slate-900'>
              Horaires Flexibles
            </h3>
            <p class='text-gray-700 text-sm'>
              Vol tôt le matin ou tard le soir ? Disponible 7j/7, même pour les
              départs à 4h du matin ou les arrivées de nuit.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Exemples de trajets -->
    <section class='py-20 bg-white'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Exemples de Trajets Fréquents
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='grid md:grid-cols-2 gap-6'>
          <div
            class='bg-gray-50 rounded-lg p-6 border-l-4 border-blue-500 shadow-lg'>
            <div class='flex items-center mb-3'>
              <Icon name='lucide:plane-takeoff' size={20} class='text-blue-500 mr-3' />
              <h3 class='font-bold text-slate-900'>
                La Roche-sur-Yon → Aéroport Nantes
              </h3>
            </div>
            <p class='text-gray-700 text-sm'>
              Pour vos vacances, voyages d'affaires, week-ends. Prise en charge
              à domicile, dépose au terminal.
            </p>
          </div>

          <div
            class='bg-gray-50 rounded-lg p-6 border-l-4 border-green-500 shadow-lg'>
            <div class='flex items-center mb-3'>
              <Icon name='lucide:plane-landing' size={20} class='text-green-500 mr-3' />
              <h3 class='font-bold text-slate-900'>
                Aéroport Nantes → La Roche-sur-Yon
              </h3>
            </div>
            <p class='text-gray-700 text-sm'>
              Retour de vacances, arrivée de visiteurs. Je vous attends à la
              sortie avec panneau nominatif si besoin.
            </p>
          </div>

          <div
            class='bg-gray-50 rounded-lg p-6 border-l-4 border-yellow-500 shadow-lg'>
            <div class='flex items-center mb-3'>
              <Icon name='lucide:train-front' size={20} class='text-yellow-500 mr-3' />
              <h3 class='font-bold text-slate-900'>
                La Roche-sur-Yon → Gare de Nantes
              </h3>
            </div>
            <p class='text-gray-700 text-sm'>
              Correspondance TGV, départ pour Paris ou autres destinations. Plus
              rapide et confortable que le TER local. Idéal aussi pour <a
                href='/taxi-professionnel-entreprise/'
                class='text-blue-600 hover:underline'
                >les déplacements professionnels vers des séminaires ou salons</a
              >.
            </p>
          </div>

          <div
            class='bg-gray-50 rounded-lg p-6 border-l-4 border-purple-500 shadow-lg'>
            <div class='flex items-center mb-3'>
              <Icon name='lucide:arrow-left-right' size={20} class='text-purple-500 mr-3' />
              <h3 class='font-bold text-slate-900'>
                Aller-Retour Aéroport (mise à disposition)
              </h3>
            </div>
            <p class='text-gray-700 text-sm'>
              Pour accueillir ou accompagner quelqu'un. Je reste disponible
              entre l'aller et le retour si nécessaire.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Comment réserver -->
    <section class='py-20 bg-gray-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-12'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Comment Réserver ?
          </h2>
          <div class='w-20 h-1 bg-yellow-400 mx-auto'></div>
        </div>

        <div class='bg-white rounded-xl shadow-lg p-8'>
          <ol class='space-y-4'>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0 mt-1'
                >1</span
              >
              <div>
                <h3 class='font-bold text-slate-900 mb-1'>
                  Appelez-moi au 06 33 96 80 23
                </h3>
                <p class='text-gray-700'>
                  Ou envoyez un message si je ne peux pas répondre immédiatement
                </p>
              </div>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0 mt-1'
                >2</span
              >
              <div>
                <h3 class='font-bold text-slate-900 mb-1'>
                  Précisez les détails
                </h3>
                <p class='text-gray-700'>
                  Date, heure, adresse départ, destination, nombre de passagers,
                  bagages
                </p>
              </div>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0 mt-1'
                >3</span
              >
              <div>
                <h3 class='font-bold text-slate-900 mb-1'>
                  Recevez votre devis
                </h3>
                <p class='text-gray-700'>
                  Je vous communique le tarif fixe immédiatement. Aucune
                  surprise.
                </p>
              </div>
            </li>
            <li class='flex items-start'>
              <span
                class='bg-yellow-400 text-slate-900 w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 flex-shrink-0 mt-1'
                >4</span
              >
              <div>
                <h3 class='font-bold text-slate-900 mb-1'>C'est réservé !</h3>
                <p class='text-gray-700'>
                  Je note votre course et vous envoie un rappel la veille du
                  départ
                </p>
              </div>
            </li>
          </ol>

          <div
            class='mt-8 bg-blue-50 rounded-lg p-4 border-l-4 border-blue-500'>
            <p class='text-sm text-gray-700'>
              <Icon name='lucide:lightbulb' size={16} class='text-blue-500 mr-2 inline' />
              <strong>Conseil :</strong> Pour les départs à l'aéroport, réservez au
              moins 24-48h à l'avance pour garantir ma disponibilité, surtout en période
              de vacances.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection faqs={faqs} />

    <!-- Services connexes -->
    <section class='py-12 bg-gray-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h3 class='text-xl font-bold text-slate-900 mb-6 text-center'>
          Découvrez aussi mes autres services
        </h3>
        <div class='grid md:grid-cols-3 gap-4'>
          <a
            href='/taxi-8-places-transport-groupe/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:users' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Taxi 8 Places</h4>
              <p class='text-gray-600 text-sm'>Départs en groupe</p>
            </div>
          </a>
          <a
            href='/taxi-rapatriement-panne-longue-distance/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:car' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Rapatriement Panne</h4>
              <p class='text-gray-600 text-sm'>Longue distance</p>
            </div>
          </a>
          <a
            href='/taxi-professionnel-entreprise/'
            class='bg-white p-4 rounded-lg shadow hover:shadow-md transition flex items-center'>
            <Icon name='lucide:briefcase' size={24} class='text-yellow-500 mr-4' />
            <div>
              <h4 class='font-bold text-slate-900'>Transport Pro</h4>
              <p class='text-gray-600 text-sm'>Déplacements business</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section
      class='py-20 bg-slate-900 text-white'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <div
          class='bg-blue-600 text-white w-20 h-20 rounded-full flex items-center justify-center mb-8 mx-auto text-3xl'>
          <Icon name='lucide:plane-takeoff' size={30} />
        </div>
        <h2 class='text-3xl md:text-4xl font-bold mb-6'>
          Ne Ratez Plus Jamais Votre Vol ou Votre Train
        </h2>
        <p class='text-xl text-gray-200 mb-4'>
          Réservez dès maintenant votre transfert vers l'aéroport de Nantes ou
          la gare
        </p>
        <p class='text-lg text-blue-200 mb-8'>
          ✓ Tarif fixe garanti ✓ Suivi de vol en temps réel ✓ Véhicule 8 places
          disponible
        </p>
        <div class='flex flex-col sm:flex-row gap-4 justify-center'>
          <a
            href='tel:0633968023'
            class='inline-block bg-yellow-400 text-slate-900 px-8 py-4 rounded-full font-bold hover:bg-yellow-500 transition transform hover:scale-105 text-lg'>
            <Icon name='lucide:phone' size={20} class='mr-2 inline' />
            Devis Gratuit - 06 33 96 80 23
          </a>
        </div>
        <p class='text-gray-300 mt-6 text-sm'>
          <Icon name='lucide:calendar-check' size={16} class='mr-2 inline' />
          Réservation recommandée 24-48h à l'avance pour garantir ma disponibilité
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <MobileCallButton />
</Layout>
