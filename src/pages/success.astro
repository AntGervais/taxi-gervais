---
import Layout from "../layouts/Layout.astro";
---

<Layout title='Demande envoyée | Taxi Anthony Gervais'>
  <main
    class='flex min-h-[100dvh] items-center justify-center bg-slate-50 px-4 py-16'>
    <div
      class='w-full max-w-md rounded-2xl bg-white p-8 text-center shadow-soft-lg ring-1 ring-slate-200'>
      <div
        class='mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-green-100'>
        <i class='fas fa-check text-3xl text-green-600'></i>
      </div>
      <h1 class='mb-3 text-2xl font-bold text-slate-900'>Demande envoyée</h1>
      <p class='mb-8 text-slate-600'>
        Merci pour votre message. Anthony vous rappelle dans les plus brefs
        délais pour confirmer votre réservation. Pour une demande urgente,
        appelez directement au
        <a
          href='tel:0633968023'
          class='font-semibold tabular-nums text-slate-900 underline underline-offset-2 hover:text-yellow-700'
          >06 33 96 80 23</a
        >.
      </p>
      <a
        href='/'
        class='inline-flex items-center gap-2 rounded-full bg-yellow-400 px-8 py-3.5 font-bold text-slate-900 transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 active:translate-y-0 active:scale-[0.98]'>
        <i class='fas fa-arrow-left text-sm'></i>
        Retour à l'accueil
      </a>
    </div>
  </main>
</Layout>
