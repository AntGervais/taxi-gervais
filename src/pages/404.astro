---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const links = [
  { href: "/#services", label: "Nos services", icon: "fas fa-list-check" },
  { href: "/tarifs/", label: "Tarifs", icon: "fas fa-euro-sign" },
  { href: "/taxi-nantes/", label: "Taxi Nantes", icon: "fas fa-plane" },
  { href: "/#contact", label: "Réserver", icon: "fas fa-calendar-check" },
];
---

<Layout
  title='Page introuvable | Taxi Anthony Gervais'
  description="Cette page n'existe pas ou a changé d'adresse. Retrouvez votre taxi à La Roche-sur-Yon."
>
  <Navbar />
  <main
    class='mx-auto flex min-h-[70vh] max-w-2xl flex-col items-center justify-center px-4 py-20 text-center sm:px-6'>
    <span
      class='mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-yellow-400 text-3xl text-slate-900'>
      <i class='fas fa-taxi'></i>
    </span>
    <p class='text-6xl font-extrabold tabular-nums tracking-tight text-slate-900'>
      404
    </p>
    <h1 class='mt-4 text-2xl font-bold text-slate-900'>Cette page a changé de route</h1>
    <p class='mt-3 max-w-md text-slate-600'>
      La page que vous cherchez n'existe plus ou a été déplacée. Reprenez depuis
      l'accueil, ou appelez directement pour réserver votre trajet.
    </p>

    <div
      class='mt-8 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center'>
      <a
        href='/'
        class='inline-flex items-center justify-center gap-2 rounded-full bg-slate-900 px-8 py-3.5 font-bold text-white transition duration-200 hover:-translate-y-0.5 hover:bg-slate-800 active:translate-y-0 active:scale-[0.98]'>
        <i class='fas fa-arrow-left text-sm'></i>
        Retour à l'accueil
      </a>
      <a
        href='tel:0633968023'
        class='shadow-brand inline-flex items-center justify-center gap-2 rounded-full bg-yellow-400 px-8 py-3.5 font-bold text-slate-900 transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 active:translate-y-0 active:scale-[0.98]'>
        <i class='fas fa-phone-alt'></i>
        <span class='tabular-nums'>06 33 96 80 23</span>
      </a>
    </div>

    <div class='mt-12 w-full border-t border-slate-200 pt-8'>
      <p class='mb-4 text-sm font-medium text-slate-500'>Pages les plus consultées</p>
      <div class='flex flex-wrap justify-center gap-3'>
        {
          links.map((link) => (
            <a
              href={link.href}
              class='inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-soft ring-1 ring-slate-200 transition hover:-translate-y-0.5 hover:text-yellow-700 hover:shadow-soft-lg'>
              <i class={`${link.icon} text-xs text-yellow-500`} />
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</Layout>
