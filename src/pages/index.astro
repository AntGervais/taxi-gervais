---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import ZoneIntervention from "../components/ZoneIntervention.astro";
import Testimonials from "../components/Testimonials.astro";
import Contact from "../components/Contact.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
import Pricing from "../components/Pricing.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title='Taxi La Roche-sur-Yon | Conventionné CPAM | Anthony Gervais 85'
  description="Taxi conventionné CPAM à La Roche-sur-Yon, disponible 24h/24 et 7j/7. Transports médicaux, gare, aéroport Nantes, rapatriement panne. Véhicule 8 places. Appelez le 06 33 96 80 23.">
  <script type='application/ld+json' slot='head'>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Comment réserver un taxi à La Roche-sur-Yon ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Appelez directement Anthony Gervais au 06 33 96 80 23, disponible 24h/24 et 7j/7. Vous pouvez aussi envoyer un SMS si la ligne est occupée. Pour les déplacements récurrents ou les courses à l'aéroport, une réservation 24 à 48h à l'avance est recommandée."
          }
        },
        {
          "@type": "Question",
          "name": "Le taxi est-il conventionné CPAM pour les transports médicaux ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui, Taxi Anthony Gervais est agréé CPAM. Les trajets médicaux (dialyse, chimiothérapie, radiothérapie, consultations spécialisées) peuvent être pris en charge par la Sécurité Sociale sur prescription médicale. Renseignez-vous auprès de votre médecin ou de votre caisse."
          }
        },
        {
          "@type": "Question",
          "name": "Quelle est la zone d'intervention du taxi ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Basé à La Roche-sur-Yon (85), Taxi Gervais intervient dans toute la Vendée : Les Sables-d'Olonne, La Tranche-sur-Mer, Saint-Gilles-Croix-de-Vie, Noirmoutier et Nantes (gare SNCF et aéroport Atlantique). Le rapatriement longue distance est également disponible sur tout le territoire."
          }
        },
        {
          "@type": "Question",
          "name": "Combien de personnes le taxi peut-il transporter ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Le véhicule dispose de 8 places, idéal pour les familles nombreuses, les groupes d'amis ou les déplacements professionnels. Il dispose également d'un grand coffre pour les bagages, même en groupe."
          }
        }
      ]
    }
  </script>
  <Navbar />
  <main>
    <Hero />
    <Services />
    <ZoneIntervention />
    <Pricing />
    <Testimonials />
    <GoogleReviews />
    <Contact />
  </main>
  <Footer />

  <!-- Mobile Call Button -->
  <div class='md:hidden fixed bottom-4 right-4 z-50'>
    <a
      href='tel:0633968023'
      aria-label='Appeler Taxi Anthony Gervais'
      class='bg-green-500 text-white w-16 h-16 rounded-full flex items-center justify-center shadow-lg hover:bg-green-600 transition animate-bounce'>
      <i class='fas fa-phone-alt text-2xl'></i>
    </a>
  </div>
</Layout>

