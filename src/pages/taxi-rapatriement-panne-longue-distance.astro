---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title='Rapatriement panne Taxi La Roche-sur-Yon | Taxi Gervais'
  description='Votre voiture en panne loin de chez vous ? Service de rapatriement taxi longue distance, pris en charge par votre assurance auto. Disponible 7j/7 en Vendée et toute la France.'>
  <script type='application/ld+json' slot='head'>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Mon assurance auto prend-elle en charge le rapatriement en taxi ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui ! La plupart des assurances auto incluent une garantie assistance qui couvre le rapatriement des passagers en cas de panne ou accident, souvent dès 0 km du domicile. Je vous fournis une facture détaillée que vous transmettez à votre assurance pour remboursement."
          }
        },
        {
          "@type": "Question",
          "name": "Combien de temps faut-il pour venir me chercher après une panne ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Je m'organise au plus vite selon votre localisation. Pour les pannes dans un rayon de 100 km, je peux généralement intervenir sous 1 à 2 heures. Pour les pannes plus éloignées, nous organisons ensemble l'intervention. Disponible 7j/7."
          }
        },
        {
          "@type": "Question",
          "name": "Que faire si je suis en panne avec toute ma famille et beaucoup de bagages ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pas de panique ! Mon taxi 8 places peut rapatrier jusqu'à 8 personnes avec leurs bagages en un seul trajet. Plus besoin d'organiser plusieurs véhicules ou de laisser des affaires sur place. Tout le monde rentre ensemble."
          }
        },
        {
          "@type": "Question",
          "name": "Quelles distances couvrez-vous pour le rapatriement ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "J'interviens partout en France pour vous ramener vers La Roche-sur-Yon et la Vendée. Je peux aussi vous rapatrier depuis la Vendée vers n'importe quelle destination en cas de panne lors de vos départs en vacances ou déplacements."
          }
        }
      ]
    }
  </script>
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section class='relative isolate overflow-hidden bg-slate-900 text-white py-20'>
      <div class='grain absolute inset-0 -z-10'></div>
      <div
        class='pointer-events-none absolute -right-40 -top-40 -z-10 h-[30rem] w-[30rem] rounded-full bg-red-500/10 blur-3xl'>
      </div>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='max-w-3xl'>
          <div
            class='mb-6 inline-flex items-center gap-2 rounded-full bg-red-500/15 px-4 py-1.5 text-sm font-semibold text-red-300 ring-1 ring-red-500/30'>
            <i class='fas fa-car-crash'></i>
            Service d'urgence disponible 7j/7
          </div>
          <h1 class='text-4xl md:text-5xl font-bold mb-6 leading-tight'>
            Rapatriement Taxi suite à une panne automobile
          </h1>
          <p class='text-xl text-slate-200 mb-4'>
            Votre véhicule est en panne loin de chez vous ? Je vous rapatrie en
            taxi longue distance vers La Roche-sur-Yon et toute la Vendée.
            Service souvent <strong class='text-yellow-400'
              >pris en charge par votre assurance auto</strong
            >.
          </p>
          <p class='text-lg text-slate-300 mb-8'>
            Disponible 7j/7, avec possibilité de rapatrier jusqu'à 8 personnes
            et leurs bagages en un seul trajet.
          </p>
          <div class='flex flex-col sm:flex-row gap-4'>
            <a
              href='tel:0633968023'
              class='shadow-brand inline-flex items-center justify-center gap-2 rounded-full bg-yellow-400 px-8 py-4 font-bold text-slate-900 transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 active:translate-y-0 active:scale-[0.98] text-center'>
              <i class='fas fa-phone-alt'></i>
              <span class='tabular-nums'>Appelez maintenant · 06 33 96 80 23</span>
            </a>
            <a
              href='#procedure'
              class='inline-flex items-center justify-center rounded-full border border-white/25 px-8 py-4 font-semibold text-white transition duration-200 hover:border-white/50 hover:bg-white/5 active:scale-[0.98] text-center'>
              Comment ça marche ?
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Situations de panne -->
    <section class='py-20 bg-white'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Quand Faire Appel à Mon Service de Rapatriement ?
          </h2>
        </div>

        <div class='grid md:grid-cols-2 gap-8'>
          <div
            class='card-accent surface surface-interactive p-8'>
            <div class='text-yellow-500 text-3xl mb-4'>
              <i class='fas fa-road'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Panne Longue Distance
            </h3>
            <p class='text-slate-700'>
              En panne sur l'autoroute ou loin de chez vous ? Je viens vous
              récupérer pour vous ramener en Vendée, quelle que soit la
              distance.
            </p>
          </div>

          <div
            class='card-accent surface surface-interactive p-8'>
            <div class='text-yellow-600 text-3xl mb-4'>
              <i class='fas fa-umbrella-beach'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Panne en Vacances
            </h3>
            <p class='text-slate-700'>
              Votre voiture tombe en panne au départ ou pendant les vacances ?
              Je peux vous conduire à destination ou vous rapatrier.
            </p>
          </div>

          <div
            class='card-accent surface surface-interactive p-8'>
            <div class='text-yellow-500 text-3xl mb-4'>
              <i class='fas fa-user-group'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Famille Nombreuse
            </h3>
            <p class='text-slate-700'>
              Mon taxi 8 places rapatrie jusqu'à 8 personnes avec bagages en un
              seul trajet. Toute la famille rentre ensemble.
            </p>
          </div>

          <div
            class='card-accent surface surface-interactive p-8'>
            <div class='text-yellow-600 text-3xl mb-4'>
              <i class='fas fa-car-burst'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Accident ou Immobilisation
            </h3>
            <p class='text-slate-700'>
              Après un accident sans gravité, votre véhicule n'est plus en état
              de rouler ? Je vous ramène pendant les démarches.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Prise en charge assurance -->
    <section class='py-20 bg-slate-50'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='surface p-8 md:p-12'>
          <div class='text-center mb-8'>
            <div
              class='bg-slate-900 text-white w-20 h-20 rounded-full flex items-center justify-center mb-6 text-4xl mx-auto'>
              <i class='fas fa-shield-halved'></i>
            </div>
            <h2 class='text-3xl font-bold text-slate-900 mb-4'>
              Pris en Charge par Votre Assurance Auto
            </h2>
            <p class='text-xl text-slate-700 max-w-3xl mx-auto'>
              La plupart des contrats d'assurance automobile incluent une <strong
                >garantie assistance rapatriement</strong
              > qui couvre le transport des passagers en cas de panne ou d'accident,
              souvent dès 0 km du domicile.
            </p>
          </div>

          <div class='grid md:grid-cols-3 gap-6 mt-12'>
            <div class='flex items-start'>
              <div
                class='bg-yellow-100 text-yellow-600 w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 mr-4 text-xl'>
                <i class='fas fa-phone-volume'></i>
              </div>
              <div>
                <h3 class='text-lg font-bold text-slate-900 mb-2'>
                  1. Appelez Votre Assurance
                </h3>
                <p class='text-slate-700 text-sm'>
                  Déclarez la panne et demandez l'accord de prise en charge.
                  Notez le numéro de dossier.
                </p>
              </div>
            </div>

            <div class='flex items-start'>
              <div
                class='bg-yellow-100 text-yellow-600 w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 mr-4 text-xl'>
                <i class='fas fa-car'></i>
              </div>
              <div>
                <h3 class='text-lg font-bold text-slate-900 mb-2'>
                  2. Je Vous Rapatrie
                </h3>
                <p class='text-slate-700 text-sm'>
                  Je viens vous chercher et vous ramène à destination en toute
                  sécurité.
                </p>
              </div>
            </div>

            <div class='flex items-start'>
              <div
                class='bg-yellow-100 text-yellow-600 w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 mr-4 text-xl'>
                <i class='fas fa-file-invoice'></i>
              </div>
              <div>
                <h3 class='text-lg font-bold text-slate-900 mb-2'>
                  3. Facture pour Remboursement
                </h3>
                <p class='text-slate-700 text-sm'>
                  Je vous fournis une facture détaillée à transmettre à votre
                  assurance.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Avantages -->
    <section class='py-20 bg-white'>
      <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Mes Atouts pour Votre Rapatriement
          </h2>
        </div>

        <div class='grid md:grid-cols-3 gap-8'>
          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div class='text-yellow-500 text-4xl mb-4'>
              <i class='fas fa-clock'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Disponible 7j/7
            </h3>
            <p class='text-slate-700'>
              Service d'urgence disponible tous les jours. Intervention rapide
              selon votre localisation.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div class='text-green-600 text-4xl mb-4'>
              <i class='fas fa-van-shuttle'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>Taxi 8 Places</h3>
            <p class='text-slate-700'>
              Mon <a
                href='/taxi-8-places-transport-groupe/'
                class='text-yellow-700 hover:underline'>véhicule 8 places</a
              > peut rapatrier jusqu'à 8 personnes avec leurs bagages en un seul trajet.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-8 text-center'>
            <div class='text-yellow-600 text-4xl mb-4'>
              <i class='fas fa-route'></i>
            </div>
            <h3 class='text-xl font-bold mb-3 text-slate-900'>
              Toutes Distances
            </h3>
            <p class='text-slate-700'>
              Rapatriement partout en France, sans limitation de distance.
              Longue expérience des trajets longue distance.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class='py-20 bg-slate-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-16'>
          <h2 class='text-3xl font-bold text-slate-900 mb-4'>
            Questions Fréquentes
          </h2>
        </div>

        <div class='space-y-6'>
          <div class='card-accent surface surface-interactive p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span
                >Mon assurance auto prend-elle en charge le rapatriement en taxi
                ?</span
              >
            </h3>
            <p class='text-slate-700 ml-8'>
              Oui ! La plupart des assurances auto incluent une garantie
              assistance qui couvre le rapatriement des passagers en cas de
              panne ou accident, souvent dès 0 km du domicile. Je vous fournis
              une facture détaillée que vous transmettez à votre assurance pour
              remboursement.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span
                >Combien de temps faut-il pour venir me chercher après une panne
                ?</span
              >
            </h3>
            <p class='text-slate-700 ml-8'>
              Je m'organise au plus vite selon votre localisation. Pour les
              pannes dans un rayon de 100 km, je peux généralement intervenir
              sous 1 à 2 heures. Pour les pannes plus éloignées, nous organisons
              ensemble l'intervention. Disponible 7j/7.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span
                >Que faire si je suis en panne avec toute ma famille et beaucoup
                de bagages ?</span
              >
            </h3>
            <p class='text-slate-700 ml-8'>
              Pas de panique ! Mon <a
                href='/taxi-8-places-transport-groupe/'
                class='text-yellow-700 hover:underline'>taxi 8 places</a
              > peut rapatrier jusqu'à 8 personnes avec leurs bagages en un seul trajet.
              Plus besoin d'organiser plusieurs véhicules. Tout le monde rentre ensemble.
            </p>
          </div>

          <div class='card-accent surface surface-interactive p-6'>
            <h3 class='text-lg font-bold text-slate-900 mb-3 flex items-start'>
              <i class='fas fa-question-circle text-yellow-500 mr-3 mt-1'></i>
              <span>Quelles distances couvrez-vous pour le rapatriement ?</span>
            </h3>
            <p class='text-slate-700 ml-8'>
              J'interviens partout en France pour vous ramener vers La
              Roche-sur-Yon et la Vendée. Je peux aussi vous rapatrier depuis la
              Vendée vers n'importe quelle destination en cas de panne lors de
              vos départs en vacances ou déplacements.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services connexes -->
    <section class='py-12 bg-slate-50'>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h3 class='text-xl font-bold text-slate-900 mb-6 text-center'>
          Découvrez aussi mes autres services
        </h3>
        <div class='grid md:grid-cols-3 gap-4'>
          <a
            href='/taxi-8-places-transport-groupe/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-users text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Taxi 8 Places</h4>
              <p class='text-slate-600 text-sm'>Idéal pour rapatriement</p>
            </div>
          </a>
          <a
            href='/taxi-gare-aeroport-nantes/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-plane text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Aéroport & Gare</h4>
              <p class='text-slate-600 text-sm'>Longue distance</p>
            </div>
          </a>
          <a
            href='/taxi-professionnel-entreprise/'
            class='surface surface-interactive p-4 flex items-center'>
            <i class='fas fa-briefcase text-yellow-500 text-2xl mr-4'></i>
            <div>
              <h4 class='font-bold text-slate-900'>Transport Pro</h4>
              <p class='text-slate-600 text-sm'>Déplacements business</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section
      class='relative isolate overflow-hidden bg-slate-900 py-20 text-white'>
      <div class='grain absolute inset-0 -z-10'></div>
      <div
        class='pointer-events-none absolute left-1/2 top-0 -z-10 h-[26rem] w-[26rem] -translate-x-1/2 rounded-full bg-red-500/10 blur-3xl'>
      </div>
      <div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <div
          class='mb-8 mx-auto flex h-20 w-20 items-center justify-center rounded-2xl bg-yellow-400 text-3xl text-slate-900 shadow-soft-lg'>
          <i class='fas fa-car-crash'></i>
        </div>
        <h2 class='text-3xl md:text-4xl font-bold mb-4'>
          Votre voiture en panne ? Je vous rapatrie
        </h2>
        <div
          class='mx-auto mb-8 max-w-2xl rounded-2xl border border-yellow-400/20 bg-yellow-400/10 p-6 text-left backdrop-blur'>
          <p class='mb-2 flex items-center gap-2 text-lg font-bold text-yellow-300'>
            <i class='fas fa-shield-halved'></i>
            Souvent pris en charge par votre assurance auto
          </p>
          <p class='text-sm text-slate-300'>
            Je vous fournis une facture détaillée pour remboursement. La plupart
            des assurances couvrent le rapatriement dès <span class='tabular-nums'
              >0</span
            > km du domicile.
          </p>
        </div>
        <p class='mb-8 text-lg text-slate-300'>
          Disponible 7j/7 · Toutes distances · Véhicule 8 places pour toute la
          famille
        </p>
        <div class='flex flex-col sm:flex-row gap-4 justify-center'>
          <a
            href='tel:0633968023'
            class='shadow-brand inline-flex items-center justify-center gap-2 rounded-full bg-yellow-400 px-8 sm:px-10 py-5 text-lg font-bold text-slate-900 transition duration-200 hover:-translate-y-0.5 hover:bg-yellow-300 active:translate-y-0 active:scale-[0.98] text-center'>
            <i class='fas fa-phone-volume'></i>
            <span class='whitespace-nowrap tabular-nums'>Urgence · 06 33 96 80 23</span>
          </a>
        </div>
        <div
          class='mt-8 flex flex-col sm:flex-row gap-6 justify-center items-center text-sm'>
          <div class='flex items-center'>
            <i class='fas fa-clock text-yellow-400 mr-2 text-xl'></i>
            <span>Intervention rapide 7j/7</span>
          </div>
          <div class='flex items-center'>
            <i class='fas fa-users text-yellow-400 mr-2 text-xl'></i>
            <span>Jusqu'à 8 passagers</span>
          </div>
          <div class='flex items-center'>
            <i class='fas fa-route text-yellow-400 mr-2 text-xl'></i>
            <span>Toute la France</span>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Bouton d'appel mobile -->
  <div class='fixed bottom-5 right-5 z-50 md:hidden'>
    <a
      href='tel:0633968023'
      aria-label='Appeler Taxi Anthony Gervais - Urgence panne'
      class='relative flex h-16 w-16 items-center justify-center rounded-full bg-green-500 text-white shadow-soft-lg transition duration-200 hover:bg-green-600 active:scale-95'>
      <span
        class='absolute inset-0 -z-10 rounded-full bg-green-500/60 motion-safe:animate-ping'
      ></span>
      <i class='fas fa-phone-alt text-2xl'></i>
    </a>
  </div>
</Layout>
